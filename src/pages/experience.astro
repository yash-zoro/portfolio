---
import BaseLayout from '../layouts/BaseLayout.astro';
import experience from '../data/experience.json';
---

<BaseLayout title="Experience">
  <section class="px-4 sm:px-6 py-16 text-white">
    <h1 class="text-3xl sm:text-4xl font-bold mb-10">Experience</h1>

    <div class="space-y-10 stagger-in">
      {experience.map((job) => (
        <div class="border-l-4 border-neon pl-5 py-1 hover:bg-white/[0.02] rounded-r-lg transition-all duration-300">
          <h2 class="text-xl font-semibold">{job.title} <span class="text-gray-400 font-normal">@ {job.company}</span></h2>
          <div class="flex flex-wrap gap-x-4 mt-1">
            <p class="text-sm text-gray-500">{job.location}</p>
            <p class="text-sm text-gray-500">{job.start} – {job.end}</p>
          </div>
          {job.description && <p class="mt-3 text-gray-300 leading-relaxed">{job.description}</p>}
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
