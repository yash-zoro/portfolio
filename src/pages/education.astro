---
import BaseLayout from '../layouts/BaseLayout.astro';
import educationRaw from '../data/education.json';

interface EducationItem {
  school: string;
  degree: string;
  start: string;
  end: string;
  notes?: string;
}

const education = educationRaw as EducationItem[];
---

<BaseLayout title="Education">
  <section class="px-4 sm:px-6 py-16 text-white">
    <h1 class="text-3xl sm:text-4xl font-bold mb-10">Education</h1>

    <div class="space-y-10 stagger-in">
      {education.map((edu) => (
        <div class="border-l-4 border-neon pl-5 py-1 hover:bg-white/[0.02] rounded-r-lg transition-all duration-300">
          <h2 class="text-xl font-semibold">{edu.school}</h2>
          <p class="text-sm text-gray-400 mt-1">{edu.degree}</p>
          <p class="text-sm text-gray-500">{edu.start} – {edu.end}</p>
          {edu.notes && <p class="mt-3 text-gray-300 leading-relaxed">{edu.notes}</p>}
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
