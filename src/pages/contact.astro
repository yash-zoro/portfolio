---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact">
  <section class="px-4 sm:px-6 py-16 text-white max-w-2xl mx-auto text-center">
    <h1 class="text-3xl sm:text-4xl font-bold mb-4">Get in Touch</h1>
    <p class="text-lg mb-10 text-gray-400">
      Whether it's a question, opportunity, or just saying hi — feel free to reach out.
    </p>

    <div class="space-y-4 text-lg text-left stagger-in">
      <a href="mailto:yashkant1125@gmail.com" class="flex items-center gap-4 p-4 rounded-lg border border-gray-800 hover:border-neon hover:bg-white/[0.02] transition-all duration-200 group">
        <svg class="w-5 h-5 text-neon shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5A2.25 2.25 0 0119.5 19.5H4.5A2.25 2.25 0 012.25 17.25V6.75A2.25 2.25 0 014.5 4.5h15A2.25 2.25 0 0121.75 6.75zM3.75 7.5l7.125 4.95a.75.75 0 00.75 0L18.75 7.5" />
        </svg>
        <span class="text-gray-300 group-hover:text-neon transition-colors">Email</span>
      </a>

      <a href="https://www.linkedin.com/in/yash-2511-kant/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 p-4 rounded-lg border border-gray-800 hover:border-neon hover:bg-white/[0.02] transition-all duration-200 group">
        <svg class="w-5 h-5 text-neon shrink-0" fill="currentColor" viewBox="0 0 24 24">
          <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8.5h4V24h-4V8.5zM8.5 8.5h3.75v2.1h.05c.52-.97 1.79-2 3.68-2 3.93 0 4.65 2.6 4.65 5.98V24h-4v-8.25c0-1.97-.04-4.5-2.75-4.5-2.76 0-3.18 2.14-3.18 4.35V24h-4V8.5z" />
        </svg>
        <span class="text-gray-300 group-hover:text-neon transition-colors">LinkedIn</span>
      </a>

      <a href="https://github.com/yash-zoro" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 p-4 rounded-lg border border-gray-800 hover:border-neon hover:bg-white/[0.02] transition-all duration-200 group">
        <svg class="w-5 h-5 text-neon shrink-0" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M12 0C5.372 0 0 5.373 0 12a12.002 12.002 0 008.207 11.386c.6.113.793-.26.793-.577v-2.175c-3.338.727-4.033-1.608-4.033-1.608-.546-1.384-1.333-1.753-1.333-1.753-1.09-.745.082-.73.082-.73 1.205.084 1.84 1.238 1.84 1.238 1.07 1.833 2.808 1.303 3.492.996.108-.775.418-1.304.762-1.604-2.665-.303-5.466-1.333-5.466-5.931 0-1.31.469-2.381 1.236-3.221-.124-.303-.536-1.523.117-3.176 0 0 1.008-.322 3.3 1.23a11.5 11.5 0 016 0c2.29-1.553 3.297-1.23 3.297-1.23.655 1.653.243 2.873.12 3.176.77.84 1.235 1.911 1.235 3.221 0 4.61-2.803 5.625-5.474 5.921.43.37.823 1.096.823 2.209v3.275c0 .32.192.694.8.576A12.005 12.005 0 0024 12c0-6.627-5.373-12-12-12z" />
        </svg>
        <span class="text-gray-300 group-hover:text-neon transition-colors">GitHub</span>
      </a>

      <a href="https://x.com/zorrrrrroooooo" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 p-4 rounded-lg border border-gray-800 hover:border-neon hover:bg-white/[0.02] transition-all duration-200 group">
        <svg class="w-5 h-5 text-neon shrink-0" fill="currentColor" viewBox="0 0 24 24">
          <path d="M22.25 2L14.8 9.25 23.5 22h-6.3l-5.25-7.5-7.6 7.5H.5l8.3-8-7.8-11h6.4l4.8 6.9L20.75 2h1.5z" />
        </svg>
        <span class="text-gray-300 group-hover:text-neon transition-colors">X (Twitter)</span>
      </a>

      <a href="/yash-resume.pdf" download class="flex items-center gap-4 p-4 rounded-lg border border-gray-800 hover:border-neon hover:bg-white/[0.02] transition-all duration-200 group">
        <svg class="w-5 h-5 text-neon shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        <span class="text-gray-300 group-hover:text-neon transition-colors">Download Resume</span>
      </a>
    </div>
  </section>
</BaseLayout>
