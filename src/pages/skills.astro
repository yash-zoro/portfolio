---
import BaseLayout from '../layouts/BaseLayout.astro';
import skills from '../data/skills.json';
---

<BaseLayout title="Skills">
  <section class="px-4 sm:px-6 py-16 text-white">
    <h1 class="text-3xl sm:text-4xl font-bold mb-10">Skills</h1>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 stagger-in">
      {skills.map((skill) => (
        <div class="bg-gray-800/60 border border-gray-700/50 text-sm px-3 py-2.5 rounded-lg hover:border-neon hover:bg-neon/10 hover:text-neon transition-all duration-200 cursor-default">
          {skill}
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
