---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Yash Kant", description = "Yash Kant — Security Engineer specializing in DLP, endpoint security, and cloud defense." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, "https://yashkant.com");
---

<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Yash Kant" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@zorrrrrroooooo" />

    <title>{title}</title>
  </head>
  <body class="bg-black text-white font-sans">
    <Navbar />
    <main class="p-4 md:p-8 max-w-4xl mx-auto animate-in">
      <slot />
    </main>
    <Footer />
  </body>
</html>
